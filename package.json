{
    "name": "tree-sitter-duckyscript",
    "version": "1.0.0",
    "description": "Tree-sitter grammar for duckyPad duckyScript",
    "main": "bindings/node",
    "keywords": [
        "tree-sitter",
        "duckyscript",
        "duckypad",
        "parser"
    ],
    "files": [
        "grammar.js",
        "binding.gyp",
        "bindings/node",
        "queries",
        "src"
    ],
    "dependencies": {
        "node-addon-api": "^8.2.2",
        "node-gyp-build": "^4.8.2"
    },
    "devDependencies": {
        "tree-sitter-cli": "^0.24.0"
    },
    "peerDependencies": {
        "tree-sitter": "^0.21.1"
    },
    "peerDependenciesMeta": {
        "tree-sitter": {
            "optional": true
        }
    },
    "scripts": {
        "install": "node-gyp-build",
        "generate": "tree-sitter generate",
        "build": "tree-sitter generate && node-gyp-build",
        "test": "tree-sitter test",
        "parse": "tree-sitter parse"
    },
    "tree-sitter": [
        {
            "scope": "source.dpds",
            "file-types": [
                "ds",
                "dpds"
            ],
            "highlights": "queries/highlights.scm",
            "locals": "queries/locals.scm"
        }
    ]
}
